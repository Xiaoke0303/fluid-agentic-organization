{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Execution Record",
  "description": "外部动作的执行记录",
  "type": "object",
  "required": ["actor", "action_type", "tool_name", "target", "timestamp", "status"],
  "properties": {
    "actor": {
      "type": "string",
      "description": "执行者标识（agent id 或 session key）"
    },
    "action_type": {
      "type": "string",
      "enum": ["web_fetch", "web_search", "file_read", "file_write", "api_call", "exec", "browser", "other"],
      "description": "动作类型"
    },
    "tool_name": {
      "type": "string",
      "description": "具体工具名称"
    },
    "target": {
      "type": "string",
      "description": "目标对象（URL、文件路径、API 端点等）"
    },
    "input_summary": {
      "type": "string",
      "description": "输入内容摘要（敏感信息脱敏）"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "执行时间（ISO 8601）"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "timeout", "partial"],
      "description": "执行状态"
    },
    "result_summary": {
      "type": "string",
      "description": "结果摘要"
    },
    "error_code": {
      "type": "string",
      "description": "错误码（若失败）"
    },
    "note": {
      "type": "string",
      "description": "补充说明"
    }
  }
}
